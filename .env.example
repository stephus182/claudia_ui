# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── IBKR Gateway ──────────────────────────────────────────────────────────────
IBKR_GATEWAY_URL=https://localhost:5055/v1/api
# Browser whose localhost cookies are read for IBKR auth: chrome, safari, firefox, edge
IBKR_AUTH_BROWSER=chrome

# ── Google Drive Cache + claudia.db Sync ─────────────────────────────────────
# Shared folder for market data cache (ibkr_core_mcp) AND claudia.db sync.
# When set, claudia.db is downloaded from Drive at session start (first session
# per process) and uploaded at stop. context.md / principles.md are also read
# from Drive each session if present — upload them via the Drive web UI.
GOOGLE_DRIVE_FOLDER_ID=1abc...xyz
GDRIVE_TOKEN_FILE=~/.ibkr_core/token.json
GDRIVE_CREDENTIALS_FILE=~/.ibkr_core/credentials.json

# ── ibkr_core_mcp SQLite Store ────────────────────────────────────────────────
IBKR_SQLITE_PATH=~/.ibkr_core/store.db

# ── IBKR Flex Query (optional — for full trade history sync) ──────────────────
IBKR_FLEX_TOKEN=
IBKR_FLEX_QUERY_ID=

# ── ClaudIA Settings ──────────────────────────────────────────────────────────
# Model: claude-opus-4-8 (default), claude-sonnet-4-6, claude-haiku-4-5-20251001
CLAUDIA_MODEL=claude-opus-4-8

# Path to docs/context.md and docs/principles.md (default: docs/)
CLAUDIA_DOCS_PATH=docs

# Path to ClaudIA's conversation database (default: data/claudia.db)
CLAUDIA_DB_PATH=data/claudia.db

# Enable voice output (Phase 2, requires: pip install "claudia_ui[voice]")
CLAUDIA_VOICE_ENABLED=false

# ── TradingView MCP Sidecar ───────────────────────────────────────────────────
# Path to tradesdontlie/tradingview-mcp built index.js.
# Leave empty to auto-discover from PATH or ~/.tradingview-mcp/build/index.js
# Setup: git clone https://github.com/tradesdontlie/tradingview-mcp
#        cd tradingview-mcp && npm install && npm run build
TRADINGVIEW_MCP_PATH=
# Chrome remote debugging port used by TradingView Desktop
TRADINGVIEW_DEBUG_PORT=9222
