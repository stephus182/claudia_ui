# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── IBKR Gateway ──────────────────────────────────────────────────────────────
IBKR_GATEWAY_URL=https://localhost:5055/v1/api
# Browser whose localhost cookies are read for IBKR auth: chrome, safari, firefox, edge
IBKR_AUTH_BROWSER=chrome

# ── Google Drive ──────────────────────────────────────────────────────────────
# Root ClaudIA folder — stores claudia.db, context.md, principles.md.
# claudia.db is downloaded at session start and uploaded at stop.
# context.md / principles.md are read from Drive each session if present
# (upload them via the Drive web UI to override local docs/).
# Get the folder ID from the Drive URL: drive.google.com/drive/folders/<ID>
GOOGLE_DRIVE_FOLDER_ID=1abc...xyz

# Subfolder for claudia.db (conversation history).
# Leave EMPTY → auto-created as 'db/' inside GOOGLE_DRIVE_FOLDER_ID on first sync.
# Set explicitly to point to a pre-existing folder.
GDRIVE_DB_FOLDER_ID=

# Cache subfolder for OHLCV Parquet files (market data).
# Leave EMPTY → auto-created as 'market_data/' inside GOOGLE_DRIVE_FOLDER_ID on first use.
# Set explicitly if you want to point to a pre-existing folder.
#
# Resulting Drive layout:
#   <GOOGLE_DRIVE_FOLDER_ID>/     ← root
#     context.md
#     principles.md
#     db/                         ← GDRIVE_DB_FOLDER_ID (auto-created if blank)
#       claudia.db
#     market_data/                ← GDRIVE_CACHE_FOLDER_ID (auto-created if blank)
#       manifest.json
#       AAPL_1D_1Y_2026-01-01.parquet
#       ...
GDRIVE_CACHE_FOLDER_ID=

GDRIVE_TOKEN_FILE=~/.ibkr_core/token_ibkr_core_mcp.json
GDRIVE_CREDENTIALS_FILE=~/.ibkr_core/credentials_ibkr_core_mcp.json

# ── ibkr_core_mcp SQLite Store ────────────────────────────────────────────────
IBKR_SQLITE_PATH=~/.ibkr_core/store.db

# ── IBKR Flex Query (optional — for full trade history sync) ──────────────────
IBKR_FLEX_TOKEN=
IBKR_FLEX_QUERY_ID=

# ── Firecrawl web scraper (optional — enables firecrawl_search and firecrawl_crawl in ClaudIA) ──
FIRECRAWL_API_KEY=

# Override the auto-created web_docs/ Drive subfolder (optional)
GDRIVE_WEB_DOCS_FOLDER_ID=

# ── ClaudIA Settings ──────────────────────────────────────────────────────────
# Model: claude-opus-4-8 (default), claude-sonnet-4-6, claude-haiku-4-5-20251001
CLAUDIA_MODEL=claude-opus-4-8

# Path to docs/context.md and docs/principles.md (default: docs/)
CLAUDIA_DOCS_PATH=docs

# Path to ClaudIA's conversation database (default: data/claudia.db)
CLAUDIA_DB_PATH=data/claudia.db

# Enable voice output (Phase 2, requires: pip install "claudia_ui[voice]")
CLAUDIA_VOICE_ENABLED=false

# ── TradingView MCP Sidecar ───────────────────────────────────────────────────
# Path to tradesdontlie/tradingview-mcp built index.js.
# Leave empty to auto-discover from PATH or ~/.tradingview-mcp/build/index.js
# Setup: git clone https://github.com/tradesdontlie/tradingview-mcp
#        cd tradingview-mcp && npm install && npm run build
TRADINGVIEW_MCP_PATH=
# Chrome remote debugging port used by TradingView Desktop
TRADINGVIEW_DEBUG_PORT=9222
